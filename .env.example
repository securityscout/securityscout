# GitHub / Slack — optional for local bootstrapping (defaults in Settings); set for real integrations
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_PAT=ghp_your-fine-grained-pat
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Optional (defaults shown)
DATABASE_URL=sqlite+aiosqlite:///./security_scout.db
REDIS_URL=redis://localhost:6379
LOG_LEVEL=INFO
# Optional: triage LLM refinement (Sonnet tier)
# ANTHROPIC_API_KEY=
# Path to repos manifest (default: ./repos.yaml)
# REPOS_CONFIG_PATH=/absolute/path/to/repos.yaml

# MCP read-only server: JSON array of client identifiers allowed to connect (empty = allow all)
# MCP_CLIENT_ALLOWLIST=["cursor","claude-code"]
